{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": {
        "directory": "server"
      },
      "config": {
        "startCommand": "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}"
      }
    },
    "frontend": {
      "source": {
        "directory": "client"
      },
      "config": {
        "buildCommand": "npm install && npm run build",
        "startCommand": "npx serve -s dist -p ${PORT:-5173}"
      }
    }
  }
}
